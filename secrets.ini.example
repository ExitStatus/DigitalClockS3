; Copy this file to "secrets.ini" and fill in your own values.
; secrets.ini is gitignored so your credentials never enter version control,
; while platformio.ini (which references these via ${secrets.*}) can be committed.
[secrets]
wifi_ssid       = YourNetworkName
wifi_password   = YourWiFiPassword
weather_api_key = your_weatherapi_key
location_lat    = 51.5074
location_lon    = -0.1278
